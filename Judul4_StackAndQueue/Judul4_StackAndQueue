class QueueReservasi:
    def __init__(self, max_size=5):
        self.MAX = max_size
        self.queue = [None] * self.MAX
        self.front = -1
        self.rear = -1

    def is_empty(self):
        return self.front == -1

    def is_full(self):
        return (self.rear + 1) % self.MAX == self.front

    def enqueue(self, nama):
        if self.is_full():
            print("Antrian reservasi penuh")
            return
        if self.is_empty():
            self.front = 0
            self.rear = 0
        else:
            self.rear = (self.rear + 1) % self.MAX
        self.queue[self.rear] = nama
        print(f"{nama} berhasil masuk antrian reservasi")

    def dequeue(self):
        if self.is_empty():
            print("Antrian reservasi kosong")
            return
        print(f"{self.queue[self.front]} memasuki ruang belajar")
        if self.front == self.rear:
            self.front = -1
            self.rear = -1
        else:
            self.front = (self.front + 1) % self.MAX

    def peek(self):
        if self.is_empty():
            print("Antrian reservasi kosong")
        else:
            print(f"Antrian terdepan: {self.queue[self.front]}")

    def display(self):
        if self.is_empty():
            print("Antrian reservasi kosong")
            return
        print("Daftar antrian reservasi:")
        i = self.front
        while True:
            print("-", self.queue[i])
            if i == self.rear:
                break
            i = (i + 1) % self.MAX

def main():
    reservasi = QueueReservasi()
    while True:
        print("\n=== ANTRIAN RESERVASI RUANG BELAJAR ===")
        print("1. Melakukan Reservasi Ruang Belajar")
        print("2. Selesai Menggunakan Ruang Belajar")
        print("3. Melihat Antrian Paling Depan")
        print("4. Menampilkan Semua Antrian")
        print("5. Keluar Dari Sistem")
        try:
            pilih = int(input("Masukkan pilihan: "))
        except ValueError:
            print("Input harus nama yang berupa huruf, tidak boleh angka!")
            continue
        if pilih == 1:
            try:
                nama = input("Masukkan nama mahasiswa: ")
                reservasi.enqueue(nama)
            except ValueError:
                print("Input harus nama yang berupa huruf, tidak boleh angka!")
        elif pilih == 2:
            reservasi.dequeue()
        elif pilih == 3:
            reservasi.peek()
        elif pilih == 4:
            reservasi.display()
        elif pilih == 5:
            print("Terimakasih telah menggunakan program reservasi ruang belajar")
            break
        else:
            print("Pilihan tidak valid, silahkan pilih ulang!")

if __name__ == "__main__":
    main()
